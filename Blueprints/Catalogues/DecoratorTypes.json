      "color": "#8E44AD",
      "pins": {
        "inputs": [
          { "id": "exec_in", "label": "", "type": "Exec", "required": true }
        ],
        "outputs": [
          { "id": "exec_out", "label": "", "type": "Exec" }
        ]
      },
      "parameters": []
    },
    {
      "id": "ForceFailure",
      "name": "Force Failure",
      "category": "Logic",
      "description": "Force le retour Failure quels que soient les résultats de l'enfant",
