        "inputs": [
          { "id": "exec_in", "label": "", "type": "Exec", "required": true }
        ],
        "outputs": [
          { "id": "exec_out", "label": "", "type": "Exec" }
        ]
      },
      "parameters": []
    },
    {
      "id": "ForceSuccess",
      "name": "Force Success",
      "category": "Logic",
