      "ShouldFlee": { "type": "bool", "value": "false" },
      "AttackTarget": { "type": "string", "value": "" },
      "FleeTarget": { "type": "string", "value": "safe_zone" },
      "AttackCooldown": { "type": "float", "value": "0.0" },
      "DamageDealt": { "type": "float", "value": "0.0" }
    },
    "global": {
      "global:TotalKills": { "type": "int", "value": "0" }
    }
  },
