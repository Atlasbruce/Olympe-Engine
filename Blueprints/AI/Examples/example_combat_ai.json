{
  "schema_version": 4,
  "graphType": "VisualScript",
  "name": "example_combat_ai",
  "description": "Combat AI: Selector chooses Attack or Flee based on health and enemy distance. 35 nodes.",
  "blackboard": {
    "local": {
      "Health": { "type": "float", "value": "100.0" },
