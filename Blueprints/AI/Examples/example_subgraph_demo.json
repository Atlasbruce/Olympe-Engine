    { "id": 10, "type": "exec", "fromNode": 3,  "fromPin": "child2", "toNode": 14, "toPin": "in" },
    { "id": 11, "type": "exec", "fromNode": 14, "fromPin": "out",    "toNode": 13, "toPin": "in" },
    { "id": 12, "type": "exec", "fromNode": 3,  "fromPin": "out",    "toNode": 8,  "toPin": "in" },
    { "id": 13, "type": "exec", "fromNode": 8,  "fromPin": "out",    "toNode": 9,  "toPin": "in" },
