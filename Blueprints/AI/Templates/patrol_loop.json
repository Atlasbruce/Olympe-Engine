{
  "schema_version": 4,
  "graphType": "VisualScript",
  "templateName": "patrol_loop",
  "description": "Ready-to-use patrol loop template: NPC moves between two configurable waypoints.",
  "blackboard": {
    "local": {
      "WaypointA": { "type": "string", "value": "wp_a" },
      "WaypointB": { "type": "string", "value": "wp_b" },
      "PatrolSpeed": { "type": "float", "value": "3.5" }
    },
    "global": {}
  },
  "nodes": [
    {
      "id": 1,
      "type": "EntryPoint",
      "name": "Start",
      "comment": "Patrol loop entry - configure WaypointA, WaypointB, PatrolSpeed in blackboard",
      "posX": 100,
      "posY": 200,
      "parameters": {}
    },
    {
      "id": 2,
      "type": "Sequence",
      "name": "PatrolSequence",
      "comment": "A->B->A->B patrol sequence",
      "posX": 320,
      "posY": 200,
      "parameters": {}
    },
    {
      "id": 3,
      "type": "AtomicTask",
      "name": "MoveToA",
      "comment": "Move to waypoint A - set WaypointA in blackboard",
      "posX": 540,
      "posY": 120,
      "parameters": {
        "taskType": "MoveToLocation",
        "targetKey": "WaypointA",
        "speedKey": "PatrolSpeed"
      }
    },
    {
      "id": 4,
      "type": "AtomicTask",
      "name": "MoveToB",
      "comment": "Move to waypoint B - set WaypointB in blackboard",
      "posX": 540,
      "posY": 280,
      "parameters": {
        "taskType": "MoveToLocation",
        "targetKey": "WaypointB",
        "speedKey": "PatrolSpeed"
      }
    },
    {
      "id": 5,
      "type": "Repeat",
      "name": "LoopForever",
      "comment": "Repeat indefinitely (count=-1) or set to a fixed number",
      "posX": 760,
      "posY": 200,
      "parameters": {
        "count": "-1"
      }
    }
  ],
  "connections": [
    { "id": 1, "type": "exec", "fromNode": 1, "fromPin": "out",    "toNode": 2, "toPin": "in" },
    { "id": 2, "type": "exec", "fromNode": 2, "fromPin": "child0", "toNode": 3, "toPin": "in" },
    { "id": 3, "type": "exec", "fromNode": 2, "fromPin": "child1", "toNode": 4, "toPin": "in" },
    { "id": 4, "type": "exec", "fromNode": 2, "fromPin": "out",    "toNode": 5, "toPin": "in" }
  ]
}
