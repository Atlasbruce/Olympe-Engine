{
    "schema_version": 4,
    "graphType": "VisualScript",
    "name": "PatrolBehaviour",
    "description": "AI patrol graph: entity moves between waypoints, briefly idles, then resumes.",
    "localBlackboard": [
        { "Key": "Position",      "Type": "Vector",  "Default": [0.0, 0.0, 0.0], "IsGlobal": false },
        { "Key": "WaypointIndex", "Type": "Int",     "Default": 0,               "IsGlobal": false },
        { "Key": "PatrolSpeed",   "Type": "Float",   "Default": 100.0,           "IsGlobal": false },
        { "Key": "CurrentState",  "Type": "String",  "Default": "Patrolling",    "IsGlobal": false }
    ],
    "nodes": [
        {
            "nodeID": 1,
            "nodeType": "EntryPoint",
            "nodeName": "Start"
        },
        {
            "nodeID": 2,
            "nodeType": "AtomicTask",
            "nodeName": "MoveToWaypoint",
            "AtomicTaskID": "Task_MoveToLocation",
            "parameters": {
                "Target": { "Type": "LocalVariable", "VariableName": "Position" },
                "Speed":  { "Type": "LocalVariable", "VariableName": "PatrolSpeed" }
            }
        },
        {
            "nodeID": 3,
            "nodeType": "Branch",
            "nodeName": "IsAtPosition"
        },
        {
            "nodeID": 4,
            "nodeType": "AtomicTask",
            "nodeName": "SetIdleState",
            "AtomicTaskID": "Task_ChangeState",
            "parameters": {
                "NewState": { "Type": "Literal", "LiteralValue": "Idle" }
            }
        },
        {
            "nodeID": 5,
            "nodeType": "Delay",
            "nodeName": "IdleWait",
            "DelaySeconds": 2.0
        },
        {
            "nodeID": 6,
            "nodeType": "AtomicTask",
            "nodeName": "SetPatrollingState",
            "AtomicTaskID": "Task_ChangeState",
            "parameters": {
                "NewState": { "Type": "Literal", "LiteralValue": "Patrolling" }
            }
        }
    ],
    "ExecConnections": [
        { "SourceNodeID": 1, "SourcePinName": "Out",       "TargetNodeID": 2, "TargetPinName": "In" },
        { "SourceNodeID": 2, "SourcePinName": "Out",        "TargetNodeID": 3, "TargetPinName": "In" },
        { "SourceNodeID": 3, "SourcePinName": "Then",       "TargetNodeID": 4, "TargetPinName": "In" },
        { "SourceNodeID": 3, "SourcePinName": "Else",       "TargetNodeID": 2, "TargetPinName": "In" },
        { "SourceNodeID": 4, "SourcePinName": "Out",        "TargetNodeID": 5, "TargetPinName": "In" },
        { "SourceNodeID": 5, "SourcePinName": "Completed",  "TargetNodeID": 6, "TargetPinName": "In" },
        { "SourceNodeID": 6, "SourcePinName": "Out",        "TargetNodeID": 2, "TargetPinName": "In" }
    ],
    "DataConnections": []
}
