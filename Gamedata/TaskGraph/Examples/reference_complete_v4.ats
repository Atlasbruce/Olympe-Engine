    {"fromNode": 7,  "fromPin": "Else",       "toNode": 9,  "toPin": "In"},
    {"fromNode": 8,  "fromPin": "Completed",  "toNode": 9,  "toPin": "In"},
    {"fromNode": 9,  "fromPin": "Loop",       "toNode": 10, "toPin": "In"},
    {"fromNode": 9,  "fromPin": "Completed",  "toNode": 11, "toPin": "In"},
    {"fromNode": 10, "fromPin": "Completed",  "toNode": 9,  "toPin": "In"},
    {"fromNode": 11, "fromPin": "Completed",  "toNode": 12, "toPin": "In"},
    {"fromNode": 12, "fromPin": "Completed",  "toNode": 13, "toPin": "In"},
    {"fromNode": 13, "fromPin": "Completed",  "toNode": 14, "toPin": "In"},
    {"fromNode": 14, "fromPin": "Out",        "toNode": 15, "toPin": "In"},
    {"fromNode": 15, "fromPin": "Completed",  "toNode": 16, "toPin": "In"}
